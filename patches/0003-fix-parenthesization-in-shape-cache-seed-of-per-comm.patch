From fa212e7bb0824705498af8311424e9592096f106 Mon Sep 17 00:00:00 2001
From: grandchildrice <kingmasatojames@gmail.com>
Date: Fri, 17 Jul 2026 19:08:59 +0900
Subject: [PATCH 03/14] fix: parenthesization in shape-cache seed of
 per-command cache

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 src/Lean/Meta/SynthInstance.lean | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/Lean/Meta/SynthInstance.lean b/src/Lean/Meta/SynthInstance.lean
index 6298170..a0110a6 100644
--- a/src/Lean/Meta/SynthInstance.lean
+++ b/src/Lean/Meta/SynthInstance.lean
@@ -1155,8 +1155,9 @@ def synthInstanceCore? (type : Expr) (maxResultSize? : Option Nat := none) : Met
             | some inst => pure (if (← assignOutParams type inst) then some inst else none)
             | none => pure none
           -- seed the per-command cache under this command's exact key
-          modify fun s => { s with cache.synthInstance := s.cache.synthInstance.insert cacheKey
-            (cachedResult?.map fun e => { expr := e, paramNames := #[], mvars := #[] }) }
+          let cachedAbst? : Option AbstractMVarsResult :=
+            cachedResult?.map fun e => { expr := e, paramNames := #[], mvars := #[] }
+          modify fun s => { s with cache.synthInstance := s.cache.synthInstance.insert cacheKey cachedAbst? }
           trace[Meta.synthInstance] "result {result?} (shape cache)"
           return result?
       trace[Meta.synthInstance.cache] "new: {type}"
-- 
2.53.0

