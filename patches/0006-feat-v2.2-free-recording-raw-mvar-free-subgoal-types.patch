+/-- (v2.2) One recorded discrTree observation: mvar-FREE subgoal type and the
 global candidate names (post erased/export filter, priority order). -/
-private abbrev QueryObs := AbstractMVarsResult × Array Name
+private abbrev QueryObs := Expr × Array Name
 
 private structure GlobalSynthCacheEntry where
   instances        : Instances
@@ -1007,11 +1012,10 @@ private builtin_initialize globalSynthCacheRef :
     IO.Ref (PHashMap SynthInstanceCacheKey GlobalSynthCacheEntry) ← IO.mkRef {}
 
 /-- (v2 tier 2) Re-run the discrTree lookup for a recorded query and compare the
-global candidate list. Mirrors the filtering in `getInstances`. Mvars are reopened
-fresh so the discrTree sees the same star patterns as at record time. -/
+global candidate list. Mirrors the filtering in `getInstances`. Recorded types
+are mvar-free by construction (v2.2). -/
 private def replayQuery (obs : QueryObs) : MetaM Bool := do
-  let (abst, expected) := obs
-  let (_, _, e) ← openAbstractMVarsResult abst
+  let (e, expected) := obs
   forallTelescopeReducing e fun _ ty => do
     match ← isClass? ty with
     | none => return expected.isEmpty
@@ -1152,7 +1156,7 @@ private def shapeSynthCacheFind? (shapeKey : ShapeKey) (fvars : Array Expr) (max
   unless sameObj e.defaultInstances (defaultInstanceExtension.getState env) do return none
   unless sameObj e.reducibilityExtra (reducibilityExtraExt.getState env) do return none
   -- v2 two-tier check with query types re-opened in the TARGET telescope
-  let targetQueries := e.queries.map fun (a, ns) => ({ a with expr := a.expr.beta fvars }, ns)
+  let targetQueries := e.queries.map fun (a, ns) => (a.beta fvars, ns)
   unless (← instancesStillValid e.instances targetQueries) do return none
   match e.resultLam? with
   | none => return some none
@@ -1169,9 +1173,9 @@ private def shapeSynthCacheInsert (shapeKey : ShapeKey) (fvars : Array Expr)
   -- telescope-close each recorded query type; bail if any escapes
   let mut closedQueries : Array QueryObs := #[]
   for (a, ns) in queries do
