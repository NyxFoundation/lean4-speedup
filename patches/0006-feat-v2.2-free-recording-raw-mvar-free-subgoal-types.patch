 abbrev SynthM := ReaderT Context $ StateRefT State MetaM
 
@@ -254,35 +257,37 @@ def getInstances (type : Expr) : MetaM (Array Instance) := do
       trace[Meta.synthInstance.instances] result.map (·.val)
       return result
 
-def mkGeneratorNode? (key mvar : Expr) : MetaM (Option GeneratorNode) := do
+def mkGeneratorNode? (key mvar : Expr) : MetaM (Option GeneratorNode × Expr) := do
   let mvarType  ← inferType mvar
   let mvarType  ← instantiateMVars mvarType
   let instances ← getInstances mvarType
   if instances.isEmpty then
-    return none
+    return (none, mvarType)
   else
     let mctx ← getMCtx
-    return some {
+    return (some {
       mvar, key, mctx, instances
       typeHasMVars := mvarType.hasMVar
       currInstanceIdx := instances.size
-    }
+    }, mvarType)
 
 /--
   Create a new generator node for `mvar` and add `waiter` as its waiter.
   `key` must be `mkTableKey mctx mvarType`. -/
 def newSubgoal (mctx : MetavarContext) (key : Expr) (mvar : Expr) (waiter : Waiter) : SynthM Unit :=
   withMCtx mctx do withTraceNode' `Meta.synthInstance do
-    let node? ← mkGeneratorNode? key mvar
-    -- (global-synth-cache v2) record the observed global candidate list, including
+    let (node?, mvarType) ← mkGeneratorNode? key mvar
+    -- (global-synth-cache v2.2) record the observed global candidate list, including
     -- the empty one — a cached FAILURE must be invalidated when candidates appear.
+    -- Only mvar-free types are recorded (O(1)); others make the entry tier-2-ineligible.
     if synthInstance.globalCache.get (← getOptions) then
-      let mvarType ← instantiateMVars (← inferType mvar)
-      let abst ← abstractMVars mvarType
-      let names := match node? with
-        | some node => node.instances.filterMap (·.val.constName?)
-        | none => #[]
-      modify fun s => { s with queryLog := s.queryLog.push (abst, names) }
+      if mvarType.hasMVar then
+        modify fun s => { s with queryLogComplete := false }
+      else
+        let names := match node? with
+          | some node => node.instances.filterMap (·.val.constName?)
+          | none => #[]
+        modify fun s => { s with queryLog := s.queryLog.push (mvarType, names) }
     match node? with
     | none      => pure ((), m!"no instances for {key}")
     | some node =>
@@ -697,7 +702,7 @@ partial def synth : SynthM (Option AbstractMVarsResult) := do
     return none
 
