-    MetaM (Option AbstractMVarsResult × Array (AbstractMVarsResult × Array Name)) :=
+    MetaM (Option AbstractMVarsResult × Array (Expr × Array Name)) :=
   withCurrHeartbeats do
      let mvar ← mkFreshExprMVar type
      let key  ← mkTableKey type
@@ -707,7 +712,7 @@ def main (type : Expr) (maxResultSize : Nat) :
      tryCatchRuntimeEx
        (do
          let (res, s) ← action.run { maxResultSize := maxResultSize, maxHeartbeats := getMaxHeartbeats (← getOptions) } |>.run {}
-         return (res, s.queryLog))
+         return (res, if s.queryLogComplete then s.queryLog else #[]))
        fun ex =>
          if ex.isRuntime then
            throwError "failed to synthesize{indentExpr type}\n{ex.toMessageData}{useDiagnosticMsg}"
@@ -990,9 +995,9 @@ could unsoundly preserve the failure within that module. Disable with
 /-- Runtime pointer identity; `false` in the logic, which can only cause a cache miss. -/
 @[implemented_by sameObjImpl] private def sameObj {α : Type} (_a _b : α) : Bool := false
 
