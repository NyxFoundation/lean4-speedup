---
 src/Lean/Elab/MutualInductive.lean | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/Lean/Elab/MutualInductive.lean b/src/Lean/Elab/MutualInductive.lean
index fb34e6f..7a8359b 100644
--- a/src/Lean/Elab/MutualInductive.lean
+++ b/src/Lean/Elab/MutualInductive.lean
@@ -1428,7 +1428,10 @@ private def addInductiveDeclAsync? (decl : Declaration) : TermElabM Bool := do
   let [ctor] := indType.ctors
     | trace[Elab.inductive] "asyncInd bail: ctor count {indType.name}"
       return false
-  if (← getEnv).header.isModule then return false
+  -- module envs: v1 supports public non-private inductives with identity export
+  -- (structural infos are exported as-is for exposed public types); private
+  -- inductives keep the sync path.
+  if (← getEnv).header.isModule && isPrivateName indType.name then return false
   -- non-recursive: no constructor FIELD may mention the type (result does, of course)
   let fieldsOk ← forallTelescope ctor.type fun fields _ =>
     fields.allM fun f => do
