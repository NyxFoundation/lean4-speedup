From 0bd374107acdf7bb3431e2252d24f93827072092 Mon Sep 17 00:00:00 2001
From: grandchildrice <kingmasatojames@gmail.com>
Date: Fri, 17 Jul 2026 22:34:41 +0900
Subject: [PATCH 05/22] feat: v2.1 adaptive circuit breaker for tier-2 replays
 (open at <25% success after 32 attempts; cap 4 replays/probe)

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 src/Lean/Meta/SynthInstance.lean | 19 ++++++++++++++++---
 1 file changed, 16 insertions(+), 3 deletions(-)

diff --git a/src/Lean/Meta/SynthInstance.lean b/src/Lean/Meta/SynthInstance.lean
index b8ecfdc..b0acd27 100644
--- a/src/Lean/Meta/SynthInstance.lean
+++ b/src/Lean/Meta/SynthInstance.lean
@@ -1028,15 +1028,28 @@ private def replayQuery (obs : QueryObs) : MetaM Bool := do
               names := names.push n
       return names == expected
 
+/-- (v2) tier-2 circuit breaker: replays cost real time, and in instance-defining
+modules (where the table churns every command) they mostly fail. Track
+(attempts, successes); once attempts ≥ 32 with a success rate < 25 %, stop
+trying tier-2 for the rest of the process — behavior degrades gracefully to v1. -/
+private builtin_initialize tier2StatsRef : IO.Ref (Nat × Nat) ← IO.mkRef (0, 0)
+
+private def tier2MaxQueries : Nat := 4
+
 /-- (v2) Two-tier instance-table validity: pointer identity (tier 1), else replay
 the recorded candidate lists (tier 2) — sound under any table mutation path. -/
 private def instancesStillValid (instances : Instances) (queries : Array QueryObs) :
     MetaM Bool := do
   if sameObj instances (instanceExtension.getState (← getEnv)) then
     return true
-  if queries.isEmpty then
-    return false -- recording was off or entry predates v2: cannot witness validity
-  queries.allM replayQuery
+  if queries.isEmpty || queries.size > tier2MaxQueries then
+    return false -- unwitnessed (pre-v2/recording off) or too expensive to replay
+  let (attempts, successes) ← tier2StatsRef.get
+  if attempts >= 32 && successes * 4 < attempts then
+    return false -- circuit open: tier 2 not paying for itself in this workload
+  let ok ← queries.allM replayQuery
+  tier2StatsRef.modify fun (a, s) => (a + 1, if ok then s + 1 else s)
+  return ok
 
 private def globalSynthCacheFind? (cacheKey : SynthInstanceCacheKey) (maxResultSize : Nat) :
     MetaM (Option (Option AbstractMVarsResult)) := do
