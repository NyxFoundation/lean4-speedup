 @[inline] private unsafe def sameObjImpl {α : Type} (a b : α) : Bool := ptrEq a b
 /-- Runtime pointer identity; `false` in the logic, which can only cause a cache miss. -/
 @[implemented_by sameObjImpl] private def sameObj {α : Type} (_a _b : α) : Bool := false
 
+/-- (v2) One recorded discrTree observation: mvar-abstracted subgoal type and the
+global candidate names (post erased/export filter, priority order). -/
+private abbrev QueryObs := AbstractMVarsResult × Array Name
+
 private structure GlobalSynthCacheEntry where
   instances        : Instances
   defaultInstances : DefaultInstances
   reducibilityExtra : SMap Name ReducibilityStatus
   maxResultSize    : Nat
   abstResult?      : Option AbstractMVarsResult
+  /-- (v2) the candidate lists this derivation observed; tier-2 validity witness -/
+  queries          : Array QueryObs := #[]
 
 private builtin_initialize globalSynthCacheRef :
     IO.Ref (PHashMap SynthInstanceCacheKey GlobalSynthCacheEntry) ← IO.mkRef {}
 
+/-- (v2 tier 2) Re-run the discrTree lookup for a recorded query and compare the
+global candidate list. Mirrors the filtering in `getInstances`. Mvars are reopened
+fresh so the discrTree sees the same star patterns as at record time. -/
+private def replayQuery (obs : QueryObs) : MetaM Bool := do
+  let (abst, expected) := obs
+  let (_, _, e) ← openAbstractMVarsResult abst
+  forallTelescopeReducing e fun _ ty => do
+    match ← isClass? ty with
+    | none => return expected.isEmpty
+    | some _ =>
+      let cands ← (← getGlobalInstancesIndex).getUnify ty
+      let cands := cands.insertionSort fun e₁ e₂ => e₁.priority < e₂.priority
+      let erased ← getErasedInstances
+      let env ← getEnv
+      let mut names : Array Name := #[]
+      for c in cands do
+        if let .const n _ := c.val then
+          unless erased.contains n do
+            unless env.isExporting && !env.contains n do
+              names := names.push n
+      return names == expected
+
+/-- (v2) Two-tier instance-table validity: pointer identity (tier 1), else replay
+the recorded candidate lists (tier 2) — sound under any table mutation path. -/
+private def instancesStillValid (instances : Instances) (queries : Array QueryObs) :
+    MetaM Bool := do
+  if sameObj instances (instanceExtension.getState (← getEnv)) then
+    return true
+  if queries.isEmpty then
+    return false -- recording was off or entry predates v2: cannot witness validity
+  queries.allM replayQuery
+
 private def globalSynthCacheFind? (cacheKey : SynthInstanceCacheKey) (maxResultSize : Nat) :
     MetaM (Option (Option AbstractMVarsResult)) := do
   unless synthInstance.globalCache.get (← getOptions) do return none
   let some e := (← globalSynthCacheRef.get).find? cacheKey | return none
   let env ← getEnv
-  unless sameObj e.instances (instanceExtension.getState env) do return none
+  unless e.maxResultSize == maxResultSize do return none
   unless sameObj e.defaultInstances (defaultInstanceExtension.getState env) do return none
   unless sameObj e.reducibilityExtra (reducibilityExtraExt.getState env) do return none
-  unless e.maxResultSize == maxResultSize do return none
+  unless (← instancesStillValid e.instances e.queries) do return none
   return some e.abstResult?
 
 private def globalSynthCacheInsert (cacheKey : SynthInstanceCacheKey) (maxResultSize : Nat)
-    (abstResult? : Option AbstractMVarsResult) : MetaM Unit := do
+    (abstResult? : Option AbstractMVarsResult) (queries : Array QueryObs) : MetaM Unit := do
   unless synthInstance.globalCache.get (← getOptions) do return ()
   let env ← getEnv
   let e : GlobalSynthCacheEntry := {
     instances := instanceExtension.getState env
     defaultInstances := defaultInstanceExtension.getState env
     reducibilityExtra := reducibilityExtraExt.getState env
-    maxResultSize, abstResult? }
+    maxResultSize, abstResult?, queries }
   globalSynthCacheRef.modify (·.insert cacheKey e)
 
