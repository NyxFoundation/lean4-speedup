---
 src/Lean/Elab/SyntheticMVars.lean | 24 +++++++++++++-----------
 1 file changed, 13 insertions(+), 11 deletions(-)

diff --git a/src/Lean/Elab/SyntheticMVars.lean b/src/Lean/Elab/SyntheticMVars.lean
index 5c4bacb..50bb54f 100644
--- a/src/Lean/Elab/SyntheticMVars.lean
+++ b/src/Lean/Elab/SyntheticMVars.lean
@@ -484,16 +484,19 @@ mutual
       let goalType ← instantiateMVars (← mvarId.getType)
       if goalType.hasExprMVar || goalType.hasLevelMVar then return false
       unless (← isProp goalType) do return false
-      -- Close the goal over its local context (the def's parameters). Bail on
-      -- let-decls (their values would need zeta) and any residual mvars.
+      -- SOUND SUBSET ONLY (v0.1): require a CLOSED goal (no user fvars in
+      -- context). Under-context by-proofs in real code are entangled with the
+      -- surrounding def's metavariable/placeholder web (shared `hc`-style
+      -- placeholders, delayed assignments, outer fvars) and cannot be soundly
+      -- outlined without solving Lean's general delayed-assignment problem —
+      -- see docs/t2a-termination-outlining.md. Empty context is capture-free.
       let lctx ← getLCtx
-      let mut fvars := #[]
       for decl in lctx do
-        if decl.isImplementationDetail then continue
-        if decl.isLet then return false
-        fvars := fvars.push decl.toExpr
-      let stmt ← instantiateMVars (← mkForallFVars fvars goalType)
+        unless decl.isImplementationDetail do return false
+      if goalType.hasFVar then return false
+      let stmt ← instantiateMVars goalType
       if stmt.hasExprMVar || stmt.hasFVar || stmt.hasLevelMVar then return false
+      let fvars : Array Expr := #[]
       let levelParams := (collectLevelParams {} stmt).params.toList
       let declName ← Term.mkAuxName `_byAsync
       let env ← getEnv
@@ -511,10 +514,9 @@ mutual
         Term.wrapAsyncAsSnapshot (desc := s!"async by-proof {declName}")
           (cancelTk? := cancelTk) fun _ => do
         setEnv async.asyncEnv
-        let value ← Meta.forallTelescope stmt fun xs body => do
-          let g ← mkFreshExprSyntheticOpaqueMVar body
-          runTactic g.mvarId! tacticCode .term
-          instantiateMVars (← mkLambdaFVars xs g)
+        let g ← mkFreshExprSyntheticOpaqueMVar stmt
+        runTactic g.mvarId! tacticCode .term
+        let value ← instantiateMVars g
         addDecl <| Declaration.thmDecl { name := declName, levelParams, type := stmt, value }
         async.commitConst (← getEnv)
         async.commitCheckEnv (← getEnv)
